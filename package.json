{
  "name": "@gbielbarbosa/react-jitsi",
  "version": "0.3.2",
  "description": "A composable React SDK for Jitsi Meet low-level API with full UI customization",
  "license": "MIT",
  "author": "Gabriel Barbosa",
  "repository": {
    "type": "git",
    "url": "https://github.com/gbielbarbosa/react-jitsi.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@radix-ui/react-hover-card": "^1.1.2",
    "@radix-ui/react-popover": "^1.1.15",
    "react-rnd": "^10.5.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}